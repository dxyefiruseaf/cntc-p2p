# App
APP_NAME=BTC BigData API
APP_ENV=development
API_VERSION=1.0.0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase
# Dùng service role ở BACKEND בלבד. Không đưa key này vào frontend hoặc commit lên GitHub.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key-optional
USE_SUPABASE=true

# Fallback public API cũ. Nếu Supabase chưa có dữ liệu, backend có thể thử đọc API này rồi fallback mock local.
PUBLIC_DATA_API_URL=https://btc-bigdata-is55a.onrender.com
USE_PUBLIC_API_FALLBACK=true

# AI provider: gemini | groq | openai | mock
AI_PROVIDER=mock
AI_MODEL=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Seed endpoint bảo vệ bằng token này nếu bật route admin seed.
ADMIN_SEED_TOKEN=change-me

# Data sync / BigData pipeline
# public_api = lấy từ API Render hiện có; binance = lấy OHLCV trực tiếp Binance + tự tính indicator.
SYNC_SOURCE=public_api
SYNC_HOURS=720
SYNC_P2P_FROM_BINANCE=true
SYNC_P2P_PUBLIC_FALLBACK=true
BINANCE_API_BASE=https://api.binance.com
BINANCE_P2P_API_URL=https://p2p.binance.com/bapi/c2c/v2/friendly/c2c/adv/search
FALLBACK_USD_VND_RATE=26000

# Feature upgrade v1 — Email alerts / billing
RESEND_API_KEY=
ALERT_FROM_EMAIL=BTC BigData Alert <onboarding@resend.dev>
ALERT_COOLDOWN_HOURS=6
FRONTEND_URL=http://localhost:5173

# VNPay Sandbox — lấy từ https://sandbox.vnpayment.vn
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8000/api/payment/return

# Optional news ticker / RSS context
NEWS_RSS_URLS=https://www.coindesk.com/arc/outboundfeeds/rss/?outputType=xml
NEWS_CACHE_TTL_SECONDS=600
# Wallet demo QR return URL. Nếu để trống, backend tự suy ra từ VNPAY_RETURN_URL.
VNPAY_WALLET_RETURN_URL=http://localhost:8000/api/wallet/topup/return

# Wallet QR demo mode for coursework.
# true  = tạo QR demo nội bộ + nút xác nhận, không cần VNPAY key, không mất tiền.
# false = dùng VNPay Sandbox thật, cần VNPAY_TMN_CODE + VNPAY_HASH_SECRET.
WALLET_DEMO_PAYMENT_ENABLED=true
